// ============================================================
//  Configuracion del pipeline - Trabajo Unidad 2
// ============================================================
//  Aqui van los VALORES y RECURSOS con los que se ejecuta el
//  pipeline. La logica (que se hace) esta en main.nf.
// ============================================================

manifest {
    name        = 'trabajo_unidad2'
    description = 'Pipeline reproducible con Nextflow, PySpark y Bash - Unidad 2'
    author      = 'Neyling Macalopu'   // <-- cambia por tu nombre completo
    version     = '0.1.0'
    mainScript  = 'main.nf'
}

// ------------------------------------------------------------
//  Parametros por defecto del pipeline.
//  Se pueden sobreescribir desde la terminal, por ejemplo:
//     nextflow run main.nf --partitions 8
// ------------------------------------------------------------
params {
    figshare_id = null
    reference   = 'input1.fasta'
    query       = 'input2.fasta'
    partitions  = 4
    outdir      = 'Results'
}

// ------------------------------------------------------------
//  Recursos asignados a cada proceso (pedido en la guia).
// ------------------------------------------------------------
process {
    cpus   = 2
    memory = '4 GB'
    time   = '1h'
}

// ------------------------------------------------------------
//  Perfiles de ejecucion. Usamos 'local' (tu propia maquina).
//     nextflow run main.nf -profile local
// ------------------------------------------------------------
profiles {
    local {
        process.executor = 'local'
    }
}

// ------------------------------------------------------------
//  Permite volver a ejecutar el pipeline sin errores de
//  "archivo ya existe" en los reportes de reproducibilidad.
// ------------------------------------------------------------
dag.overwrite      = true
report.overwrite   = true
trace.overwrite    = true
timeline.overwrite = true
