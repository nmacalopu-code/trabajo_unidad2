manifest {
    name        = 'trabajo_unidad2'
    description = 'Pipeline reproducible con Nextflow, PySpark y Bash - Unidad 2'
    author      = 'Neyling Yuriko Teresa Macalopu Rimachi'
    version     = '0.2.0'
    mainScript  = 'main.nf'
}

params {
    // ID del registro publico de Figshare (obligatorio)
    figshare_id  = null

    // Archivos del registro que usa el pipeline
    reference    = 'Genoma_referencia.fasta'
    query        = 'Secuenciacion4_correctedshortReads.fasta'

    // Si es true descarga los 7 archivos del registro (~3.4 GB).
    // Por defecto descarga solo los dos que el analisis necesita.
    download_all = false

    // Numero de particiones de Spark
    partitions   = 4

    outdir       = 'Results'
}

process {
    cpus   = 2
    memory = '4 GB'
    time   = '1h'
}

profiles {
    local {
        process.executor = 'local'
    }
}

dag.overwrite      = true
report.overwrite   = true
trace.overwrite    = true
timeline.overwrite = true
